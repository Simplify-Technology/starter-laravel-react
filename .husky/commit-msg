#!/usr/bin/env sh
set -e

if [ "${SKIP_GIT_HOOKS-}" = "1" ]; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -n "$REPO_ROOT" ]; then
  cd "$REPO_ROOT"
fi

ISSUE_HELPER="scripts/git/get-issue-id.sh"
if [ -n "$REPO_ROOT" ]; then
  ISSUE_HELPER="$REPO_ROOT/$ISSUE_HELPER"
fi

MSG_FILE="$1"

if [ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ]; then
  echo "commit-msg: arquivo de mensagem inválido." >&2
  exit 1
fi

FIRST_LINE="$(sed -n '1p' "$MSG_FILE")"

case "$FIRST_LINE" in
  Merge\ *|Revert\ *|fixup\!\ *|squash\!\ *)
    exit 0
    ;;
esac

BRANCH_NAME="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

if [ "$BRANCH_NAME" = "main" ] || [ "$BRANCH_NAME" = "develop" ]; then
  echo "commit-msg: não é permitido commitar diretamente em '$BRANCH_NAME'." >&2
  exit 1
fi

if [ -z "$BRANCH_NAME" ] || [ "$BRANCH_NAME" = "HEAD" ]; then
  exit 0
fi

ISSUE_ID="$(sh "$ISSUE_HELPER" 2>/dev/null || true)"

if [ -z "$ISSUE_ID" ]; then
  echo "commit-msg: branch precisa conter ID de issue." >&2
  echo "  Ex.: PRO-123-minha-feature ou 12345-minha-feature" >&2
  exit 1
fi

if printf '%s' "$FIRST_LINE" | grep -Eq "^\\[$ISSUE_ID\\]:[[:space:]]?"; then
  exit 0
fi

if printf '%s' "$FIRST_LINE" | grep -Eq "^$ISSUE_ID:|^$ISSUE_ID[[:space:]]"; then
  exit 0
fi

echo "commit-msg: mensagem precisa conter o ID da issue da branch ($ISSUE_ID)." >&2
echo "  Dica: rode 'git commit --amend' e ajuste a 1ª linha (ou deixe o hook prefixar)." >&2
exit 1