#!/usr/bin/env sh
set -e

if [ "${SKIP_GIT_HOOKS-}" = "1" ]; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -n "$REPO_ROOT" ]; then
  cd "$REPO_ROOT"
fi

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pre-commit: pnpm não encontrado. Rode: pnpm install" >&2
  exit 1
fi

pnpm -s exec lint-staged